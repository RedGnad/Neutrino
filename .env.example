# Mantle network — pick one. Phase 2 (Sept 2026 onwards) is mainnet.
NEUTRINO_NETWORK=mantle                    # 'mantle' (mainnet) or 'mantle_sepolia'
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
# MANTLE_RPC=                              # explicit override (optional)
MANTLESCAN_API_KEY=                        # contract verification

# --- Wallets / signing ---
DEPLOYER_PRIVATE_KEY=0x...                 # for forge script Deploy.s.sol; never commit
AGENT_RUNNER_PRIVATE_KEY=0x...             # signs decision logs and execution txs in /api/run-agent

# --- Reference price feed ---
TWELVE_DATA_API_KEY=                       # https://twelvedata.com (free tier 8 req/min)

# --- LLM narration (Anthropic Claude) ---
# Either CLAUDE_API_KEY or ANTHROPIC_API_KEY works; code accepts both.
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=

# --- Deployed contracts (filled after `forge script script/Deploy.s.sol`) ---
NEXT_PUBLIC_RWA_AGENT_ADDRESS=
NEXT_PUBLIC_RWA_DECISION_LOGGER_ADDRESS=
NEXT_PUBLIC_DEFAULT_AGENT_ID=1

# --- On-chain execution (Phase 2, mainnet only) ---
EXECUTE_ON_CHAIN=false                     # 'true' to enable Fluxion swap + INIT supply
EXECUTE_ACTION=move-to-stable-yield        # 'allocate' or 'move-to-stable-yield'
EXECUTE_AMOUNT_USDC_BASE_UNITS=1000000     # 1 USDC = 1_000_000 (USDC has 6 decimals)
EXECUTE_SLIPPAGE_BPS=50                    # 50 bps = 0.5%
